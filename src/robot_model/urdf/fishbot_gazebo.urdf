<?xml version="1.0"?>
<robot name="fishbot">

    <!-- Robot Footprint -->
    <link name="base_footprint" />

    <joint name="base_joint" type="fixed">
        <parent link="base_footprint" />
        <child link="base_link" />
        <origin xyz="0.0 0.0 0.047" rpy="0 0 0" />
    </joint>

    <!-- base link -->
    <link name="base_link">
        <visual>
            <origin xyz="0 0 0.0" rpy="0 0 0" />
            <geometry>
                <cylinder length="0.08" radius="0.12" />
            </geometry>
            <material name="blue">
                <color rgba="0.1 0.1 1.0 0.5" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0.0" rpy="0 0 0" />
            <geometry>
                <cylinder length="0.08" radius="0.12" />
            </geometry>
            <material name="blue">
                <color rgba="0.1 0.1 1.0 0.5" />
            </material>
        </collision>
        <inertial>
            <origin xyz="-0.05 0 -0.03" rpy="0 0 0" />
            <mass value="6.0" />
            <inertia ixx="0.0248" ixy="0" ixz="0" iyy="0.0248" iyz="0" izz="0.0432" />
        </inertial>
    </link>

    <!-- laser link -->
    <link name="laser_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <cylinder length="0.02" radius="0.02" />
            </geometry>
            <material name="black">
                <color rgba="0.0 0.0 0.0 0.5" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <cylinder length="0.02" radius="0.02" />
            </geometry>
            <material name="black">
                <color rgba="0.0 0.0 0.0 0.5" />
            </material>
        </collision>
        <inertial>
            <mass value="0.05" />
            <inertia ixx="0.0000067" ixy="0" ixz="0" iyy="0.0000067" iyz="0" izz="0.0000100" />
        </inertial>
    </link>

    <!-- laser joint -->
    <joint name="laser_joint" type="fixed">
        <parent link="base_link" />
        <child link="laser_link" />
        <origin xyz="0 0 0.04" />
    </joint>

    <link name="imu_link">
        <visual>
            <origin xyz="0 0 0.0" rpy="0 0 0" />
            <geometry>
                <box size="0.02 0.02 0.02" />
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0.0" rpy="0 0 0" />
            <geometry>
                <box size="0.02 0.02 0.02" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.03" />
            <inertia ixx="0.0000020" ixy="0" ixz="0" iyy="0.0000020" iyz="0" izz="0.0000020" />
        </inertial>
    </link>

    <!-- imu joint -->
    <joint name="imu_joint" type="fixed">
        <parent link="base_link" />
        <child link="imu_link" />
        <origin xyz="0 0 0" />
    </joint>


    <link name="left_wheel_link">
        <visual>
            <origin xyz="0 0 0" rpy="1.57079 0 0" />
            <geometry>
                <cylinder length="0.04" radius="0.032" />
            </geometry>
            <material name="black">
                <color rgba="0.0 0.0 0.0 0.5" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="1.57079 0 0" />
            <geometry>
                <cylinder length="0.04" radius="0.032" />
            </geometry>
            <material name="black">
                <color rgba="0.0 0.0 0.0 0.5" />
            </material>
        </collision>
        <inertial>
            <mass value="0.35" />
            <inertia ixx="0.0001363" ixy="0" ixz="0" iyy="0.0001792" iyz="0" izz="0.0001363" />
        </inertial>
    </link>

    <link name="right_wheel_link">
        <visual>
            <origin xyz="0 0 0" rpy="1.57079 0 0" />
            <geometry>
                <cylinder length="0.04" radius="0.032" />
            </geometry>
            <material name="black">
                <color rgba="0.0 0.0 0.0 0.5" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="1.57079 0 0" />
            <geometry>
                <cylinder length="0.04" radius="0.032" />
            </geometry>
            <material name="black">
                <color rgba="0.0 0.0 0.0 0.5" />
            </material>
        </collision>
        <inertial>
            <mass value="0.35" />
            <inertia ixx="0.0001363" ixy="0" ixz="0" iyy="0.0001792" iyz="0" izz="0.0001363" />
        </inertial>
    </link>

    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link" />
        <child link="left_wheel_link" />
        <origin xyz="0.0 0.10 -0.015" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link" />
        <child link="right_wheel_link" />
        <origin xyz="0.0 -0.10 -0.015" />
        <axis xyz="0 1 0" />
    </joint>

    <gazebo reference="left_wheel_link">
        <mu1 value="5.0" />
        <mu2 value="0.8" />
        <fdir1 value="1 0 0" />
        <slip1 value="0.0" />
        <slip2 value="0.05" />
        <kp value="250000.0" />
        <kd value="25.0" />
        <material>Gazebo/Black</material>
    </gazebo>

    <gazebo reference="right_wheel_link">
        <mu1 value="5.0" />
        <mu2 value="0.8" />
        <fdir1 value="1 0 0" />
        <slip1 value="0.0" />
        <slip2 value="0.05" />
        <kp value="250000.0" />
        <kd value="25.0" />
        <material>Gazebo/Black</material>
    </gazebo>

    <link name="rear_caster_swivel_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="0.018 0.018 0.012" />
            </geometry>
            <material name="black">
                <color rgba="0.0 0.0 0.0 0.5" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="0.018 0.018 0.012" />
            </geometry>
            <material name="black">
                <color rgba="0.0 0.0 0.0 0.5" />
            </material>
        </collision>
        <inertial>
            <mass value="0.05" />
            <inertia ixx="0.0000020" ixy="0" ixz="0" iyy="0.0000020" iyz="0" izz="0.0000027" />
        </inertial>
    </link>

    <joint name="rear_caster_swivel_joint" type="continuous">
        <parent link="base_link" />
        <child link="rear_caster_swivel_link" />
        <origin xyz="-0.105 0.0 -0.002" />
        <axis xyz="0 0 1" />
        <dynamics damping="0.45" friction="0.08" />
    </joint>

    <link name="rear_caster_wheel_link">
        <visual>
            <origin xyz="0 0 0" rpy="1.57079 0 0" />
            <geometry>
                <cylinder length="0.012" radius="0.018" />
            </geometry>
            <material name="black">
                <color rgba="0.0 0.0 0.0 0.5" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="1.57079 0 0" />
            <geometry>
                <cylinder length="0.012" radius="0.018" />
            </geometry>
            <material name="black">
                <color rgba="0.0 0.0 0.0 0.5" />
            </material>
        </collision>
        <inertial>
            <mass value="0.13" />
            <inertia ixx="0.0000137" ixy="0" ixz="0" iyy="0.0000211" iyz="0" izz="0.0000137" />
        </inertial>
    </link>

    <joint name="rear_caster_wheel_joint" type="continuous">
        <parent link="rear_caster_swivel_link" />
        <child link="rear_caster_wheel_link" />
        <origin xyz="-0.015 0.0 -0.027" />
        <axis xyz="0 1 0" />
        <dynamics damping="0.05" friction="0.0" />
    </joint>

    <gazebo reference="rear_caster_swivel_link">
        <material>Gazebo/Black</material>
    </gazebo>

    <gazebo reference="rear_caster_wheel_link">
        <mu1 value="0.8" />
        <mu2 value="0.15" />
        <fdir1 value="1 0 0" />
        <slip1 value="0.02" />
        <slip2 value="0.2" />
        <kp value="120000.0" />
        <kd value="12.0" />
        <material>Gazebo/Black</material>
    </gazebo>

    <gazebo reference="laser_link">
        <material>Gazebo/Black</material>
    </gazebo>

    <gazebo reference="imu_link">
        <sensor name="imu" type="imu">
            <topic>imu</topic>
            <always_on>true</always_on>
            <update_rate>100</update_rate>
            <visualize>true</visualize>
            <gz_frame_id>imu_link</gz_frame_id>
            <imu>
                <angular_velocity>
                    <x>
                        <noise type="gaussian">
                            <mean>0.0</mean>
                            <stddev>0.0</stddev>
                            <bias_mean>0.00000</bias_mean>
                            <bias_stddev>0.000000</bias_stddev>
                        </noise>
                    </x>
                    <y>
                        <noise type="gaussian">
                            <mean>0.0</mean>
                            <stddev>0</stddev>
                            <bias_mean>0.00000</bias_mean>
                            <bias_stddev>0.000000</bias_stddev>
                        </noise>
                    </y>
                    <z>
                        <noise type="gaussian">
                            <mean>0.0</mean>
                            <stddev>0.0</stddev>
                            <bias_mean>0.00000</bias_mean>
                            <bias_stddev>0.000000</bias_stddev>
                        </noise>
                    </z>
                </angular_velocity>
                <linear_acceleration>
                    <x>
                        <noise type="gaussian">
                            <mean>0.0</mean>
                            <stddev>0.0</stddev>
                            <bias_mean>0.0</bias_mean>
                            <bias_stddev>0.00</bias_stddev>
                        </noise>
                    </x>
                    <y>
                        <noise type="gaussian">
                            <mean>0.0</mean>
                            <stddev>0.0</stddev>
                            <bias_mean>0.0</bias_mean>
                            <bias_stddev>0.00</bias_stddev>
                        </noise>
                    </y>
                    <z>
                        <noise type="gaussian">
                            <mean>0.0</mean>
                            <stddev>0.0</stddev>
                            <bias_mean>0.0</bias_mean>
                            <bias_stddev>0.00</bias_stddev>
                        </noise>
                    </z>
                </linear_acceleration>
            </imu>
        </sensor>
    </gazebo>

    <gazebo reference="laser_link">
        <sensor name="gpu_lidar" type="gpu_lidar">
            <topic>scan</topic>
            <gz_frame_id>laser_link</gz_frame_id>
            <always_on>true</always_on>
            <visualize>true</visualize>
            <update_rate>20</update_rate>
            <pose>0 0 0.075 0 0 0</pose>
            <lidar>
                <scan>
                    <horizontal>
                        <samples>360</samples>
                        <resolution>1.000000</resolution>
                        <min_angle>0.000000</min_angle>
                        <max_angle>6.280000</max_angle>
                    </horizontal>
                </scan>
                <range>
                    <min>0.120000</min>
                    <max>10</max>
                    <resolution>0.015000</resolution>
                </range>
                <noise>
                    <type>gaussian</type>
                    <mean>0.0</mean>
                    <stddev>0.00</stddev>
                </noise>
            </lidar>
        </sensor>
    </gazebo>

    <gazebo>
        <plugin name="gz::sim::systems::Imu" filename="gz-sim-imu-system">
        </plugin>

        <plugin name="gz::sim::systems::Sensors" filename="gz-sim-sensors-system">
            <render_engine>ogre2</render_engine>
        </plugin>

        <plugin name="gz::sim::systems::DiffDrive" filename="gz-sim-diff-drive-system">
            <!-- 控制话题 -->
            <topic>cmd_vel</topic>

            <!-- 更新频率 -->
            <odom_publish_frequency>50</odom_publish_frequency>

            <!-- 轮子关节 -->
            <left_joint>left_wheel_joint</left_joint>
            <right_joint>right_wheel_joint</right_joint>

            <!-- 运动学参数 -->
            <wheel_separation>0.2</wheel_separation>
            <wheel_radius>0.032</wheel_radius>

            <!-- 限制参数 -->
            <max_wheel_torque>4.0</max_wheel_torque>
            <max_wheel_acceleration>2.5</max_wheel_acceleration>

            <!-- 发布选项 -->
            <publish_odom>false</publish_odom>
            <publish_odom_tf>false</publish_odom_tf>
            <publish_wheel_tf>false</publish_wheel_tf>
        </plugin>

        <plugin name="gz::sim::systems::JointStatePublisher" filename="gz-sim-joint-state-publisher-system">
            <topic>joint_states</topic>
            <update_rate>30</update_rate>
            <joint_name>right_wheel_joint</joint_name>
            <joint_name>left_wheel_joint</joint_name>
        </plugin>

        <plugin name="gz::sim::systems::OdometryPublisher" filename="gz-sim-odometry-publisher-system">
            <dimensions>3</dimensions>
            <odom_topic>/odom</odom_topic>
            <tf_topic>/tf</tf_topic>
            <odom_frame>odom</odom_frame>
            <robot_base_frame>base_footprint</robot_base_frame>
        </plugin>

    </gazebo>

</robot>
